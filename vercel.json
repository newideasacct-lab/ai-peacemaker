{
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "framework": null,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/build/client/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|json|png|jpg|jpeg|svg|ico|map))",
      "dest": "/build/client/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/build/server/index.js"
    }
  ]
}
